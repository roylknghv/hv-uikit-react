{
  "name": "@hitachivantara/app-shell-ui",
  "version": "2.3.3",
  "type": "module",
  "private": false,
  "author": "Hitachi Vantara UI Kit Team",
  "description": "AppShell Component",
  "homepage": "https://github.com/pentaho/hv-uikit-react",
  "sideEffects": false,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pentaho/hv-uikit-react.git",
    "directory": "packages/app-shell-ui"
  },
  "bugs": "https://github.com/pentaho/hv-uikit-react/issues",
  "scripts": {
    "build": "npm run clean && vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "clean": "npx rimraf dist package",
    "prepublishOnly": "npm run build && npx clean-publish"
  },
  "dependencies": {
    "@emotion/css": "^11.10.5",
    "@emotion/react": "^11.10.5",
    "@emotion/styled": "^11.10.5",
    "@hitachivantara/app-shell-events": "^2.0.5",
    "@hitachivantara/app-shell-i18next": "^0.2.1",
    "@hitachivantara/app-shell-navigation": "^2.1.13",
    "@hitachivantara/app-shell-services": "^2.0.4",
    "@hitachivantara/app-shell-shared": "^2.3.2",
    "@hitachivantara/uikit-react-core": "^6.9.0",
    "@hitachivantara/uikit-react-icons": "^6.0.5",
    "@mui/material": "^7.0.2",
    "i18next": "^24.2.2",
    "i18next-browser-languagedetector": "^8.0.3",
    "react-error-boundary": "^6.0.0",
    "react-helmet-async": "^2.0.1",
    "react-i18next": "15.7.1",
    "uid": "^2.0.2"
  },
  "devDependencies": {
    "vite-plugin-static-copy": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./locales/*": "./src/locales/*"
  },
  "publishConfig": {
    "access": "public",
    "directory": "package",
    "module": "dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json",
      "./locales/*": "./dist/locales/*"
    }
  },
  "clean-publish": {
    "withoutPublish": true,
    "tempDir": "package"
  }
}
