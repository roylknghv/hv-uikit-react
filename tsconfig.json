{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "customConditions": ["@hitachivantara/source"]
  },
  "include": [
    ".config/*.ts",
    "*.config.ts",
    ".storybook/**/*",
    "apps",
    "docs",
    "packages",
    "templates"
  ],
  "exclude": ["node_modules", "**/dist", "packages/*/package"]
}
