{
  "name": "hv-uikit-react",
  "type": "module",
  "private": true,
  "description": "UI Kit React components library.",
  "homepage": "https://github.com/pentaho/hv-uikit-react",
  "author": "Hitachi Vantara UI Kit Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pentaho/hv-uikit-react.git"
  },
  "bugs": {
    "url": "https://github.com/pentaho/hv-uikit-react/issues"
  },
  "license": "Apache-2.0",
  "scripts": {
    "dev": "npm run dev -w apps/app",
    "doc": "storybook dev -p 6006",
    "nextra": "npm run dev -w apps/docs",
    "clean": "lerna run clean",
    "build": "lerna run build",
    "build:doc": "storybook build -o dist --quiet --test",
    "build:app": "npm run build -w apps/app",
    "build:nextra": "npm run build -w apps/docs",
    "test": "lerna run test -- --run",
    "test:storybook": "vitest --project=storybook",
    "test:coverage": "lerna run test -- --run --coverage",
    "check": "npm run lint && npm run prettier && npm run typecheck",
    "prettier": "prettier --log-level warn --check .",
    "prettier:fix": "prettier --write .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install .config/husky",
    "publish-dry": "lerna publish --no-push --registry \"http://localhost:4873/\"",
    "publish": "lerna publish"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@emotion/css": "^11.11.0",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@fortawesome/fontawesome-svg-core": "^6.6.0",
    "@fortawesome/free-solid-svg-icons": "^6.6.0",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@hitachivantara/uikit-config": "*",
    "@hitachivantara/uikit-uno-preset": "*",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@iconify-json/ph": "^1.2.1",
    "@mdx-js/react": "^3.1.0",
    "@microsoft/api-extractor": "^7.58.7",
    "@mui/material": "^7.3.7",
    "@playwright/test": "^1.56.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-links": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^22.19.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.0.17",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "arquero": "^5.3.0",
    "chromatic": "^12.0.0",
    "clsx": "^2.0.0",
    "cpy-cli": "^5.0.0",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "encoding": "^0.1.13",
    "happy-dom": "^20.0.0",
    "husky": "^8.0.3",
    "lerna": "^9.0.0",
    "license-compliance": "^3.0.0",
    "oxlint": "^1.63.0",
    "prettier": "^3.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^6.0.1",
    "storybook": "^10.3.6",
    "swr": "^2.2.4",
    "typescript": "^5.8.2",
    "unocss": "^66.4.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.0.17"
  },
  "overrides": {
    "storybook": "$storybook",
    "lerna": {
      "@npmcli/package-json": "^7.0.2"
    }
  },
  "packageManager": "npm@11.11.0+sha512.f36811c4aae1fde639527368ae44c571d050006a608d67a191f195a801a52637a312d259186254aa3a3799b05335b7390539cf28656d18f0591a1125ba35f973",
  "prettier": "@hitachivantara/uikit-config/prettier",
  "license-compliance": {
    "extends": "@hitachivantara/uikit-config/licenses"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "templates"
  ]
}
